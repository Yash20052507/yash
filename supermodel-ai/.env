# supermodel-ai/.env (Project Root)

# --- General Docker Compose Settings ---
NODE_ENV=development # Options: development, production. Affects backend logging, frontend build, etc.
COMPOSE_PROJECT_NAME=supermodelai

# --- PostgreSQL Configuration ---
POSTGRES_USER=supermodeladmin
POSTGRES_PASSWORD=supermodelsecretpassword # Change this in your actual .env file!
POSTGRES_DB=supermodel_ai_db
POSTGRES_PORT=5432 # Host port for PostgreSQL if you need to access it directly

# --- MongoDB Configuration ---
MONGO_INITDB_ROOT_USERNAME=supermodelmongoadmin
MONGO_INITDB_ROOT_PASSWORD=supermodelmongosecret # Change this in your actual .env file!
MONGODB_INITDB_DATABASE=supermodel_ai_mongo_db # The DB name the app will use for its data
MONGODB_PORT=27017 # Host port for MongoDB if direct access is needed

# --- Redis Configuration ---
REDIS_PORT=6379 # Host port for Redis if direct access is needed

# --- Backend Service Configuration ---
BACKEND_PORT=5000 # Internal port the backend service listens on (must match Dockerfile EXPOSE if var used there)
BACKEND_PORT_HOST=5001 # Host port to map to the backend service (e.g., access backend at localhost:5001)

# JWT Configuration (Loaded by backend via env_file)
JWT_SECRET=a_very_secure_secret_for_jwt_!@#$%^&*()_+ # Change this in your actual .env file!
JWT_EXPIRATION=7d

# OpenAI API Key (Loaded by backend)
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE # Replace with your actual key

# Pinecone Configuration (Loaded by backend)
PINECONE_API_KEY=YOUR_PINECONE_API_KEY_HERE # Replace with your actual key
PINECONE_ENVIRONMENT=YOUR_PINECONE_ENVIRONMENT # e.g., "gcp-starter", "us-west1-gcp" etc.
PINECONE_INDEX=supermodel-ai-prod # Replace with your Pinecone index name
PINECONE_PROJECT_NAME=YOUR_PINECONE_PROJECT_ID_HERE # Pinecone Project ID (often needed for client v2.x)

# Backend Application Specific Settings (Loaded by backend)
LOG_LEVEL=debug # Options: error, warn, info, http, verbose, debug, silly
# CORS_ORIGIN is used by the backend to allow requests from the frontend.
# When running via Docker Compose with Nginx, the request comes from Nginx (localhost:FRONTEND_PORT_HOST).
# If frontend is served on port 80 (default), then http://localhost (or http://localhost:80) is correct.
# If you change FRONTEND_PORT_HOST, update this.
CORS_ORIGIN=http://localhost

# Rate Limiting (Backend)
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100 # Max requests per windowMs per IP

# --- Frontend Service Configuration ---
FRONTEND_PORT_HOST=80 # Host port for the frontend Nginx service (e.g., access frontend at http://localhost:80 or http://localhost)

# Frontend Runtime Environment Variables (passed via Nginx or fetched by app)
# These are examples. The current setup uses Nginx proxy, so React app itself doesn't need these at runtime.
# If it did, they'd typically be set in public/env.js or similar, or via build ARGs if static.
# REACT_APP_API_URL=/api # This is effectively handled by Nginx proxy_pass
# REACT_APP_WEBSOCKET_URL=/ # WebSocket connections go to Nginx root, then proxied for /socket.io
# REACT_APP_TITLE=SuperModel AI (from public/index.html and .env.example for local dev)
