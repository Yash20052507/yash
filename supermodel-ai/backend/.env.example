# Server Configuration
PORT=5000
NODE_ENV=development

# Database URLs
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/supermodel_ai
MONGODB_URI=mongodb://localhost:27017/supermodel_ai
REDIS_URI=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=1d # e.g., 1d, 7d, 30d

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone Configuration (for vector embeddings)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here
PINECONE_INDEX=your_pinecone_index_name_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100 # Max requests per windowMs

# Logging
LOG_LEVEL=info # e.g., error, warn, info, http, verbose, debug, silly
